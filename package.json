{
  "name": "@harpeblue/signal",
  "version": "0.1.0",
  "description": "CSS-first design system for HarpeBlue projects.",
  "license": "MIT",
  "author": "harpeblue <hspe2507@gmail.com>",
  "homepage": "https://github.com/harpeblue/harpeblue-signal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harpeblue/harpeblue-signal.git"
  },
  "bugs": {
    "url": "https://github.com/harpeblue/harpeblue-signal/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css",
    "dist/*.css",
    "src/**/*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": "./dist/harpeblue-signal.css",
    "./css": "./dist/harpeblue-signal.css",
    "./tokens": "./src/tokens/index.css",
    "./themes": "./src/themes/index.css",
    "./components": "./src/components/index.css"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "node scripts/check.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
